ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-me-in-production

# Em desenvolvimento, deixe DATABASE_URL vazio/ausente para usar SQLite.
# DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://trackbook:trackbook@localhost:5432/trackbook

# Em dev com Expo/dispositivo fisico, "*" facilita acesso via IP local.
# Em producao, use dominios explicitos e nunca "*".
ALLOWED_HOSTS=*

# Em dev, pode ficar aberto para Expo Web, emuladores e IP local.
# Em producao, use CORS_ALLOW_ALL_ORIGINS=False e preencha CORS_ALLOWED_ORIGINS.
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
CORS_ALLOWED_ORIGIN_REGEXES=^http://192\\.168\\.\\d{1,3}\\.\\d{1,3}:8081$,^http://10\\.0\\.2\\.2:8081$

DB_CONN_MAX_AGE=0
DB_SSL_REQUIRE=False
